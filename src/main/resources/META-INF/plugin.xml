<idea-plugin>
    <id>dev.slne.surf.idea.surf-idea-plugin</id>
    <name>Surf Framework</name>
    <vendor url="https://github.com/SLNE-Development/">SLNE-Development</vendor>

    <description><![CDATA[
        <p>
            The <b>Surf Framework</b> plugin adds first-class IntelliJ IDEA support for the
            <a href="https://github.com/SLNE-Development/">Surf ecosystem</a>, covering
            <b>surf-api</b>, <b>surf-redis</b>, and <b>surf-database-r2dbc</b>.
        </p>

        <h3>Features</h3>
        <ul>
            <li><b>Inspections &amp; quick-fixes</b> — Validates handler signatures, annotations,
                serialization requirements, naming conventions, and more with actionable fixes.</li>
            <li><b>Code generation</b> — Generate Paper/Velocity event listeners and Redis
                event/request handlers from the <em>Generate</em> menu.</li>
            <li><b>Line markers</b> — Gutter icons for Redis event handlers, event classes, and
                publish calls for quick navigation between related symbols.</li>
            <li><b>Postfix templates</b> — Surf-Redis postfix completions for common patterns.</li>
            <li><b>Inlay hints</b> — Displays resolved Redis key prefixes for sync structure
                declarations.</li>
            <li><b>Framework detection</b> — Automatically detects Surf libraries on the classpath
                and activates relevant features via facets.</li>
            <li><b>Internal API gating</b> — Flags usage of <code>@InternalAPIMarker</code>-annotated
                symbols from library dependencies as errors.</li>
            <li><b>Tool window</b> — A dedicated Surf Redis tool window for an overview of
                registered handlers and events.</li>
        </ul>

        <h3>Supported Frameworks</h3>
        <ul>
            <li><b>surf-api</b> — Paper, Velocity, and Core platform support.</li>
            <li><b>surf-redis</b> — Annotation-driven Redis event and request/response handler
                pattern (<code>@OnRedisEvent</code>, <code>@HandleRedisRequest</code>).</li>
            <li><b>surf-database-r2dbc</b> — Transaction context inspections.</li>
        </ul>

        <p><em>Requires Kotlin K2 mode.</em></p>
    ]]></description>

    <depends>com.intellij.modules.compose</depends>
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>

    <resource-bundle>messages.SurfBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Surf-API -->
        <facetType implementation="dev.slne.surf.idea.surfideaplugin.surfapi.facet.SurfApiFacetType"/>
        <!--        <framework.detector implementation="dev.slne.surf.idea.surfideaplugin.surfapi.facet.SurfApiFrameworkDetector"/>-->

        <localInspection
                language="kotlin"
                groupPath="Surf framework"
                groupName="General"
                shortName="MustBeInvokedByOverridersInspection"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="dev.slne.surf.idea.surfideaplugin.surfapi.inspections.common.MustBeInvokedByOverridersInspection"
                key="inspection.must.be.invoked.by.overriders.display.name"
        />
        <localInspection language="kotlin"
                         groupPath="Surf framework"
                         groupKey="inspection.surfapi.group.name"
                         shortName="InternalApiUsage"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.surfapi.inspections.internalapi.InternalApiUsageInspection"
                         key="inspection.surfapi.internal.api.usage.display.name"
        />

        <completion.contributor language="kotlin"
                                order="first,before KotlinCompletionContributor"
                                implementationClass="dev.slne.surf.idea.surfideaplugin.surfapi.completion.InternalApiCompletionContributor"/>
        <implicitUsageProvider
                implementation="dev.slne.surf.idea.surfideaplugin.surfapi.velocity.references.VelocityEventHandlerImplicitUsageProvider"
        />
        <implicitUsageProvider
                implementation="dev.slne.surf.idea.surfideaplugin.surfapi.paper.references.PaperEventHandlerImplicitUsageProvider"/>
        <lang.inspectionSuppressor language="kotlin"
                                   implementationClass="dev.slne.surf.idea.surfideaplugin.surfapi.velocity.references.VelocityEventHandlerInspectionSuppressor"
        />
        <lang.inspectionSuppressor language="kotlin"
                                   implementationClass="dev.slne.surf.idea.surfideaplugin.surfapi.paper.references.PaperEventHandlerInspectionSuppressor"/>

        <!-- Surf-Redis -->
        <facetType implementation="dev.slne.surf.idea.surfideaplugin.redis.facet.SurfRedisFacetType"/>
        <!--        <framework.detector implementation="dev.slne.surf.idea.surfideaplugin.redis.facet.SurfRabbitFrameworkDetector"/>-->

        <postStartupActivity implementation="dev.slne.surf.idea.surfideaplugin.common.facet.SurfFacetSetupActivity"/>

        <localInspection
                language="kotlin"
                groupPath="Surf framework"
                groupKey="inspection.redis.group.name"
                shortName="RedisEventMissingSerializable"
                enabledByDefault="true"
                level="ERROR"
                implementationClass="dev.slne.surf.idea.surfideaplugin.redis.inspections.RedisEventMissingSerializableInspection"
                key="inspection.redis.event.missing.serializable.display.name"
        />
        <localInspection
                language="kotlin"
                groupPath="Surf framework"
                groupKey="inspection.redis.group.name"
                shortName="RedisHandlerSuspendFunction"
                enabledByDefault="true"
                level="ERROR"
                implementationClass="dev.slne.surf.idea.surfideaplugin.redis.inspections.RedisHandlerSuspendInspection"
                key="inspection.redis.handler.suspend.function.display.name"
        />
        <localInspection
                language="kotlin"
                groupPath="Surf framework"
                groupKey="inspection.redis.group.name"
                shortName="RedisEventHandlerParameterInspection"
                enabledByDefault="true"
                level="ERROR"
                implementationClass="dev.slne.surf.idea.surfideaplugin.redis.inspections.RedisEventHandlerParameterInspection"
                key="inspection.redis.event.handler.parameter.inspection.display.name"
        />
        <localInspection language="kotlin"
                         groupPath="Surf framework"
                         groupKey="inspection.redis.group.name"
                         shortName="RedisRequestHandlerParameterInspection"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.redis.inspections.RedisRequestHandlerParameterInspection"
                         key="inspection.redis.request.handler.parameter.inspection.display.name"
        />
        <localInspection language="kotlin"
                         groupPath="Surf framework"
                         groupKey="inspection.redis.group.name"
                         shortName="RedisRequestHandlerParameterNameInspection"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.redis.inspections.RedisRequestHandlerParameterNameInspection"
                         key="inspection.redis.request.handler.parameter.name.inspection.display.name"
        />
        <localInspection language="kotlin"
                         groupPath="Surf framework"
                         groupKey="inspection.redis.group.name"
                         shortName="RedisEventHandlerParameterNameInspection"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.redis.inspections.RedisEventHandlerParameterNameInspection"
                         key="inspection.redis.event.handler.parameter.name.inspection.display.name"
        />
        <localInspection language="kotlin"
                         groupKey="inspection.redis.group.name"
                         groupPath="Surf framework"
                         shortName="RedisHandlerModifierInspection"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.redis.inspections.RedisHandlerModifierInspection"
                         key="inspection.redis.handler.modifier.inspection.display.name"
        />
        <localInspection language="kotlin"
                         groupPath="Surf framework"
                         groupKey="inspection.redis.group.name"
                         shortName="RedisRequestHandlerMissingRespond"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.redis.inspections.RedisRequestHandlerMissingRespondInspection"
                         key="inspection.redis.request.handler.missing.respond.display.name"
        />
        <localInspection language="kotlin"
                         groupPath="Surf framework"
                         groupKey="inspection.redis.group.name"
                         shortName="RedisRequestHandlerContextLeak"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.redis.inspections.RedisRequestHandlerContextLeakInspection"
                         key="inspection.redis.request.handler.context.leak.display.name"
        />
        <localInspection language="kotlin"
                         groupPath="Surf framework"
                         groupKey="inspection.redis.group.name"
                         shortName="RedisHandlerReturnType"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.redis.inspections.RedisHandlerReturnTypeInspection"
                         key="inspection.redis.handler.return.type.display.name"
        />

        <implicitUsageProvider
                implementation="dev.slne.surf.idea.surfideaplugin.redis.references.RedisEventHandlerImplicitUsageProvider"/>
        <lang.inspectionSuppressor language="kotlin"
                                   implementationClass="dev.slne.surf.idea.surfideaplugin.redis.references.RedisEventHandlerInspectionSuppressor"/>
        <codeInsight.lineMarkerProvider language="kotlin"
                                        implementationClass="dev.slne.surf.idea.surfideaplugin.redis.makers.RedisEventHandlerLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="kotlin"
                                        implementationClass="dev.slne.surf.idea.surfideaplugin.redis.makers.RedisEventClassLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="kotlin"
                                        implementationClass="dev.slne.surf.idea.surfideaplugin.redis.makers.RedisPublishCallLineMarkerProvider"/>
        <codeInsight.template.postfixTemplateProvider language="kotlin"
                                                      implementationClass="dev.slne.surf.idea.surfideaplugin.redis.postfix.SurfRedisPostfixTemplateProvider"/>
        <codeInsight.declarativeInlayProvider group="OTHER_GROUP"
                                              implementationClass="dev.slne.surf.idea.surfideaplugin.redis.hints.SurfRedisSyncKeyInlayHintsProvider"
                                              isEnabledByDefault="true"
                                              language="kotlin"
                                              nameKey="inlay.hints.redis.sync.id.name"
                                              descriptionKey="inlay.hints.redis.sync.id.description"
                                              providerId="surf.redis.sync.structure.id.inlay.hints"
        />
        <codeInsight.parameterNameHintsSuppressor
                implementation="dev.slne.surf.idea.surfideaplugin.redis.hints.SurfRedisSyncParameterHintsSuppressor"/>
        <facet.toolWindow facetIdList="surf-redis"
                          factoryClass="dev.slne.surf.idea.surfideaplugin.redis.toolwindow.SurfRedisToolWindowFactory"
                          id="SurfRedis"
                          anchor="right"
                          icon="AllIcons.Toolwindows.ToolWindowPalette"
        />

        <!-- Surf Rabbit -->
        <localInspection language="kotlin"
                         groupPath="Surf framework"
                         groupKey="inspection.surfrabbit.group.name"
                         enabledByDefault="true"
                         level="ERROR"
                         shortName="RabbitPacketIsNotSerializable"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.rabbitmq.inspection.RabbitPacketIsNotSerializableInspection"
                         key="inspection.rabbit.packet.is.not.serializable.display.name"
        />
        <localInspection language="kotlin"
                         groupPath="Surf framework"
                         groupKey="inspection.surfrabbit.group.name"
                         enabledByDefault="true"
                         level="ERROR"
                         shortName="RabbitPacketIsObject"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.rabbitmq.inspection.RabbitPacketIsObjectInspection"
                         key="inspection.rabbit.packet.is.object.display.name"
        />
        <localInspection language="kotlin"
                         groupPath="Surf framework"
                         groupKey="inspection.surfrabbit.group.name"
                         enabledByDefault="true"
                         level="ERROR"
                         shortName="RabbitHandlerModifierInspection"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.rabbitmq.inspection.RabbitHandlerModifierInspection"
                         key="inspection.rabbit.handler.modifier.inspection.display.name"
        />


        <facetType implementation="dev.slne.surf.idea.surfideaplugin.rabbitmq.facet.SurfRabbitFacetType"/>
        <codeInsight.lineMarkerProvider language="kotlin"
                                        implementationClass="dev.slne.surf.idea.surfideaplugin.rabbitmq.markers.RabbitRequestHandlerClassLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="kotlin"
                                        implementationClass="dev.slne.surf.idea.surfideaplugin.rabbitmq.markers.RabbitRequestCallLineMarkerProvider"/>

        <completion.contributor language="kotlin"
                                implementationClass="dev.slne.surf.idea.surfideaplugin.rabbitmq.completion.RabbitRespondCompletionContributor"/>

        <internalFileTemplate name="Rabbit Request Packet"/>
        <internalFileTemplate name="Rabbit Response Packet"/>
        <internalFileTemplate name="Rabbit Handler Class"/>
    </extensions>


    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <actions>
        <!-- Surf-API -->
        <action id="dev.slne.surf.idea.surfideaplugin.surfapi.paper.generation.GeneratePaperEventListenerCodeInsightAction"
                class="dev.slne.surf.idea.surfideaplugin.surfapi.paper.generation.GeneratePaperEventListenerCodeInsightAction"
                text="Generate Paper Event Listener">
            <add-to-group group-id="GenerateGroup" anchor="last"/>
        </action>

        <action id="dev.slne.surf.idea.surfideaplugin.surfapi.velocity.generation.GenerateVelocityEventListenerCodeInsightAction"
                class="dev.slne.surf.idea.surfideaplugin.surfapi.velocity.generation.GenerateVelocityEventListenerCodeInsightAction"
                text="Generate Velocity Event Listener">
            <add-to-group group-id="GenerateGroup" anchor="last"/>
        </action>

        <!-- Surf-Redis -->
        <action id="dev.slne.surf.idea.surfideaplugin.redis.generation.GenerateRedisEventHandlerCodeInsightAction"
                class="dev.slne.surf.idea.surfideaplugin.redis.generation.GenerateRedisEventHandlerCodeInsightAction"
                text="Generate Redis Event Handler">
            <add-to-group group-id="GenerateGroup" anchor="last"/>
        </action>
        <action id="dev.slne.surf.idea.surfideaplugin.redis.generation.GenerateRedisRequestHandlerCodeInsightAction"
                class="dev.slne.surf.idea.surfideaplugin.redis.generation.GenerateRedisRequestHandlerCodeInsightAction"
                text="Generate Redis Request Handler">
            <add-to-group group-id="GenerateGroup" anchor="last"/>
        </action>

        <!-- Surf Rabbit -->
        <action id="dev.slne.surf.idea.surfideaplugin.rabbitmq.generation.GenerateRabbitRequestHandlerCodeInsightAction"
                class="dev.slne.surf.idea.surfideaplugin.rabbitmq.generation.GenerateRabbitRequestHandlerCodeInsightAction"
                text="Generate RabbitMQ Request Handler">
            <add-to-group group-id="GenerateGroup" anchor="last"/>
        </action>
        <action id="Surf.NewRabbitPacket"
                class="dev.slne.surf.idea.surfideaplugin.rabbitmq.actions.NewRabbitPacketAction"
                text="Rabbit Packet"
                description="Create a new Rabbit Request or Response packet"
                icon="AllIcons.Providers.RabbitMQ"
        >
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="Kotlin.NewFile"/>
        </action>
        <action id="surf.rabbit.NewHandlerAction"
                class="dev.slne.surf.idea.surfideaplugin.rabbitmq.actions.NewRabbitHandlerAction"
                text="Rabbit Handler"
                description="Creates a new Rabbit Handler for a RabbitRequestPacket">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="Surf.NewRabbitPacket"/>
        </action>
    </actions>
</idea-plugin>