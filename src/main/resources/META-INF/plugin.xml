                         groupKey="inspection.surfrabbit.rpc.group.name"
                         enabledByDefault="true"
                         level="ERROR"
                         shortName="RpcServiceProperty"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.rabbitmq.inspection.rpc.RpcServicePropertyInspection"
                         key="inspection.rabbit.rpc.service.property.display.name"
        />
        <localInspection language="kotlin"
                         groupPath="Surf framework"
