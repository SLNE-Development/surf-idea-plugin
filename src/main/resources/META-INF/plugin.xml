        />

        <!-- Surf-RabbitMQ RPC -->
        <localInspection language="kotlin"
                         groupPath="Surf framework"
                         groupKey="inspection.surfrabbit.rpc.group.name"
                         enabledByDefault="true"
                         level="ERROR"
                         shortName="RpcServiceMustBeInterface"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.rabbitmq.inspection.rpc.RpcServiceMustBeInterfaceInspection"
                         key="inspection.rabbit.rpc.service.must.be.interface.display.name"
        />
        <localInspection language="kotlin"
                         groupPath="Surf framework"
                         groupKey="inspection.surfrabbit.rpc.group.name"
                         enabledByDefault="true"
                         level="ERROR"
                         shortName="RpcServiceTypeParameter"
                         implementationClass="dev.slne.surf.idea.surfideaplugin.rabbitmq.inspection.rpc.RpcServiceTypeParameterInspection"
                         key="inspection.rabbit.rpc.service.type.parameter.display.name"
        />
        <localInspection language="kotlin"
